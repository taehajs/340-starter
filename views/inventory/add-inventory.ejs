<%- include('../partials/header') %>
<h1>Add Inventory</h1>
<p><%= message %></p>

<form method="post" action="/inv/add-inventory">
  <label for="inv_make">Make:</label>
  <input type="text" id="inv_make" name="inv_make" value="<%= inv_make || '' %>" required>

  <label for="inv_model">Model:</label>
  <input type="text" id="inv_model" name="inv_model" value="<%= inv_model || '' %>" required>

  <label for="inv_year">Year:</label>
  <input type="number" id="inv_year" name="inv_year" value="<%= inv_year || '' %>" required min="1900" max="2100">

  <label for="inv_price">Price:</label>
  <input type="number" id="inv_price" name="inv_price" value="<%= inv_price || '' %>" required min="0">

  <label for="classification_id">Classification:</label>
  <%- classificationList %>

  <button type="submit">Add Inventory</button>
</form>

<%- include('../partials/footer') %>